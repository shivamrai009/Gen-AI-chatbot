# ── Copy this file to .env.local for local development ────────────────────────
# Do NOT commit .env.local to git.
#
# For Vercel production, set these in:
#   Project → Settings → Environment Variables

# Required — get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Required in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# A weak default is used in dev so the app starts without this set.
JWT_SECRET=

# Optional — Vercel KV (Upstash Redis) for persistent storage.
# Without these the app uses an in-memory store (data resets on server restart).
# Create a KV database at vercel.com → Storage → Create Database, then copy the values here.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional — Groq API key for follow-up question fallback (llama-3.1-8b-instant).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Optional — override data directory for vector_index.json (defaults to ./data)
DATA_DIR=
