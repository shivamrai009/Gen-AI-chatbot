# Gemini API key (required for AI responses)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key (optional fallback)
GROQ_API_KEY=your_groq_api_key_here

# JWT secret (required — use a long random string)
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Vercel KV (set automatically by Vercel KV integration, or manually for local)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Data directory for vector_index.json (defaults to ./data)
DATA_DIR=
