# ── Copy this file to .env and fill in your values ───────────────
# Do NOT commit .env to git.

# App
APP_NAME=GitLab Knowledge AI
APP_ENV=development           # change to "production" when deploying
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS — comma-separated list of allowed frontend origins
# Dev:        http://localhost:5173
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Auth — generate a strong secret for production
# Run: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# AI Providers — get keys from:
#   Gemini:  https://aistudio.google.com/app/apikey
#   Groq:    https://console.groq.com/keys  (optional fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
ROUTER_MODEL=gemini-2.0-flash
CRITIC_MODEL=gemini-2.0-flash

# Vector / retrieval
EMBEDDING_DIMENSIONS=3072
MAX_CONTEXT_CHUNKS=4
MAX_REGENERATION_ATTEMPTS=1
OOD_SIMILARITY_THRESHOLD=0.12
VECTOR_BACKEND=local
VECTOR_INDEX_PATH=data/vector_index.json
GRAPH_PATH=data/knowledge_graph.json
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_GRAPH_WEIGHT=0.4

# Storage paths
USERS_PATH=data/users.json
CHAT_DB_PATH=data/chats.db
TELEMETRY_PATH=data/telemetry.log

# Index builder settings (only needed when running scripts/build_index.py)
SOURCE_URLS=https://handbook.gitlab.com,https://about.gitlab.com/direction/
CRAWL_DEPTH=1
MAX_CHILD_LINKS_PER_PAGE=12
MAX_EXPANDED_PAGES_PER_SEED=25
